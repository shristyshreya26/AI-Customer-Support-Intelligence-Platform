# --- Trained model artifacts ---
# DistilBERT checkpoints (250MB+ each) live on Hugging Face Hub instead —
# see README for the repo IDs. Everything else in models/ (XGBoost .pkl
# files, encoders, similarity index, embeddings) is small enough to commit
# directly and stays tracked in git.
models/issue_classifier/
models/emotion_detector/

# --- Data ---
# The raw/processed datasets can also be large; exclude by default.
# Remove this line if your dataset is small enough to version normally.
data/raw/
data/processed/*.csv

# --- Python ---
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/
*.egg-info/
.eggs/

# --- Virtual environments ---
venv/
env/
.venv/
ai-support/

# --- Jupyter ---
.ipynb_checkpoints

# --- OS/editor clutter ---
.DS_Store
Thumbs.db
.vscode/
.idea/

# --- Training run outputs ---
results/

# --- Secrets (never commit API keys) ---
.env
*.key

# --- Streamlit ---
.streamlit/secrets.toml